<!-- FAQ -->
<section class="py-16 py-lg-32 bg-slate-50">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-5">
                <h2 class="text-indigo-600 font-bold tracking-widest uppercase mb-3 text-sm">Got Questions?</h2>
                <h3 class="text-3xl font-black text-slate-900 mb-4">Frequently Asked Questions</h3>
                <p class="text-lg text-slate-600 mb-6">Can't find what you're looking for? Feel free to reach out to our support team.</p>
                <a href="/Home/Contact" class="btn-premium no-underline">Contact Support</a>
            </div>
            <div class="col-lg-7">
                <div class="accordion" id="faqAccordion">
                    <div class="accordion-item border-0 mb-4 rounded-3xl overflow-hidden shadow-sm">
                        <h2 class="accordion-header">
                            <button class="accordion-button bg-white font-bold text-slate-900" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                How do I become a member?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                            <div class="accordion-body bg-white text-slate-600">
                                Simply visit our library with a valid ID proof and fill out the membership form. Membership is free for students and costs ₹500/year for others.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item border-0 mb-4 rounded-3xl overflow-hidden shadow-sm">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-white font-bold text-slate-900" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                How many books can I borrow at once?
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body bg-white text-slate-600">
                                Members can borrow up to 5 books at a time for a period of 14 days. Extensions are available upon request.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item border-0 mb-4 rounded-3xl overflow-hidden shadow-sm">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-white font-bold text-slate-900" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                What are the library timings?
                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body bg-white text-slate-600">
                                We're open Monday to Saturday from 8:00 AM to 8:00 PM. Our digital catalog is accessible 24/7.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item border-0 mb-4 rounded-3xl overflow-hidden shadow-sm">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-white font-bold text-slate-900" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                                Are there any late fees?
                            </button>
                        </h2>
                        <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body bg-white text-slate-600">
                                Yes, late fees are ₹10 per day per book. We send reminders 3 days before the due date.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
