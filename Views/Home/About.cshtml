                </div>
            </div>
            <div class="col-md-3">
                <div class="text-center group cursor-pointer">
                    <div class="relative mb-6 overflow-hidden rounded-3xl">
                        <img src="https://i.pravatar.cc/400?img=9" class="w-full aspect-square object-cover group-hover:scale-110 transition-transform duration-500" alt="Team">
                        <div class="absolute inset-0 bg-gradient-to-t from-indigo-600/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end justify-center pb-6">
                            <div class="flex gap-3">
                                <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-indigo-600"><i class="fab fa-linkedin-in"></i></div>
                            </div>
                        </div>
                    </div>
                    <h4 class="text-xl font-bold text-slate-900 mb-1">Sneha Patel</h4>
