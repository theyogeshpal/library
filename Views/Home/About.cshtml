                                <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-indigo-600"><i class="fab fa-linkedin-in"></i></div>
                            </div>
                        </div>
                    </div>
                    <h4 class="text-xl font-bold text-slate-900 mb-1">Priya Mehta</h4>
                    <p class="text-indigo-600 font-bold text-sm uppercase tracking-widest">Digital Manager</p>
