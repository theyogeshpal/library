@{
    Layout = "_WebLayout";
}

<section class="py-32 bg-slate-50 relative overflow-hidden">
    <div class="container relative z-10">
        <div class="max-w-4xl">
            <h1 class="display-3 fw-black text-slate-900 mb-6 animate__animated animate__fadeInUp">Our Mission is to <span class="text-indigo-600">Democratize</span> Knowledge.</h1>
            <p class="text-2xl text-slate-600 leading-relaxed animate__animated animate__fadeInUp" style="animation-delay: 0.1s;">Founded in 2024, RiskFlight has evolved from a local initiative into a world-class resource center dedicated to intellectual growth and community empowerment.</p>
        </div>
    </div>
</section>

<section class="py-32 bg-white">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <div class="relative">
                    <img src="https://images.unsplash.com/photo-1544640805-35c0fa000792?auto=format&fit=crop&q=80&w=800"
                         alt="History" class="rounded-4xl shadow-2xl relative z-10">
                    <div class="absolute -bottom-10 -right-10 w-64 h-64 bg-indigo-600 rounded-4xl -z-0 opacity-10"></div>
                </div>
            </div>
            <div class="col-lg-6 ps-lg-5">
                <h2 class="text-indigo-600 font-bold mb-4">Our Story</h2>
                <h3 class="text-4xl font-black text-slate-900 mb-8">From a Small Shelf to a Digital Empire</h3>
                <div class="space-y-6 text-lg text-slate-600">
                    <p>RiskFlight Library was born out of a simple need: a quiet place to read. What started with just 500 books in a rented room has now expanded into a massive collection of over 50,000 titles across all disciplines.</p>
                    <p>We believe that libraries are the cornerstones of democracy and innovation. That's why we've integrated cutting-edge technology with traditional library values to create a space that serves every generation.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-32 bg-slate-900 text-white">
    <div class="container text-center mb-20">
        <h3 class="text-5xl font-black mb-6">What We Stand For</h3>
        <p class="text-xl text-indigo-200">Our core values guide everything we do.</p>
    </div>
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="p-10 rounded-4xl border border-white/10 hover:bg-white/5 transition-all text-center">
                    <div class="w-20 h-20 rounded-full bg-indigo-600 flex items-center justify-center text-3xl mx-auto mb-8"><i class="fas fa-universal-access"></i></div>
                    <h4 class="text-2xl font-bold mb-4">Accessibility</h4>
                    <p class="text-slate-400">Knowledge should be free and accessible to everyone, regardless of their background.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-10 rounded-4xl border border-white/10 hover:bg-white/5 transition-all text-center">
                    <div class="w-20 h-20 rounded-full bg-indigo-600 flex items-center justify-center text-3xl mx-auto mb-8"><i class="fas fa-lightbulb"></i></div>
                    <h4 class="text-2xl font-bold mb-4">Innovation</h4>
                    <p class="text-slate-400">We constantly evolve our digital systems to provide the best user experience.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-10 rounded-4xl border border-white/10 hover:bg-white/5 transition-all text-center">
                    <div class="w-20 h-20 rounded-full bg-indigo-600 flex items-center justify-center text-3xl mx-auto mb-8"><i class="fas fa-hands-helping"></i></div>
                    <h4 class="text-2xl font-bold mb-4">Community</h4>
                    <p class="text-slate-400">Building a network of learners who support and inspire each other every day.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-32 bg-white">
    <div class="container text-center">
        <div class="row g-5">
            <div class="col-md-3">
                <div class="text-6xl font-black text-indigo-600 mb-2">24/7</div>
                <div class="text-slate-500 font-bold uppercase tracking-widest text-sm">Online Support</div>
            </div>
            <div class="col-md-3">
                <div class="text-6xl font-black text-indigo-600 mb-2">15+</div>
                <div class="text-slate-500 font-bold uppercase tracking-widest text-sm">Expert Staff</div>
            </div>
            <div class="col-md-3">
                <div class="text-6xl font-black text-indigo-600 mb-2">100%</div>
                <div class="text-slate-500 font-bold uppercase tracking-widest text-sm">Satisfaction</div>
            </div>
            <div class="col-md-3">
                <div class="text-6xl font-black text-indigo-600 mb-2">₹0</div>
                <div class="text-slate-500 font-bold uppercase tracking-widest text-sm">Late Fees*</div>
            </div>
        </div>
    </div>
</section>

<!-- Timeline -->
<section class="py-16 py-lg-32 bg-slate-50">
    <div class="container">
        <div class="text-center mb-12">
            <h2 class="text-indigo-600 font-bold tracking-widest uppercase mb-3 text-sm">Our Journey</h2>
            <h3 class="text-3xl font-black text-slate-900">Milestones That Matter</h3>
        </div>
        <!-- Desktop Timeline -->
        <div class="max-w-4xl mx-auto d-none d-md-block">
            <div class="relative">
                <div class="absolute left-1/2 transform -translate-x-1/2 h-full w-1 bg-indigo-200"></div>
                <div class="mb-16 flex items-center">
                    <div class="w-1/2 pr-12 text-right">
                        <div class="p-8 rounded-3xl bg-white shadow-lg border border-slate-100">
                            <h4 class="text-2xl font-bold text-slate-900 mb-2">Foundation</h4>
                            <p class="text-slate-600">Started with 500 books in a small rented space, driven by passion for knowledge sharing.</p>
                        </div>
                    </div>
                    <div class="w-12 h-12 bg-indigo-600 rounded-full flex items-center justify-center text-white font-bold z-10 relative flex-shrink-0 text-sm">2020</div>
                    <div class="w-1/2 pl-12"></div>
                </div>
                <div class="mb-16 flex items-center">
                    <div class="w-1/2 pr-12"></div>
                    <div class="w-12 h-12 bg-indigo-600 rounded-full flex items-center justify-center text-white font-bold z-10 relative flex-shrink-0 text-sm">2021</div>
                    <div class="w-1/2 pl-12">
                        <div class="p-8 rounded-3xl bg-white shadow-lg border border-slate-100">
                            <h4 class="text-2xl font-bold text-slate-900 mb-2">Digital Transformation</h4>
                            <p class="text-slate-600">Launched our online catalog system, making books accessible 24/7 to all members.</p>
                        </div>
                    </div>
                </div>
                <div class="mb-16 flex items-center">
                    <div class="w-1/2 pr-12 text-right">
                        <div class="p-8 rounded-3xl bg-white shadow-lg border border-slate-100">
                            <h4 class="text-2xl font-bold text-slate-900 mb-2">Expansion</h4>
                            <p class="text-slate-600">Moved to a larger facility with 10,000+ books and dedicated study spaces.</p>
                        </div>
                    </div>
                    <div class="w-12 h-12 bg-indigo-600 rounded-full flex items-center justify-center text-white font-bold z-10 relative flex-shrink-0 text-sm">2022</div>
                    <div class="w-1/2 pl-12"></div>
                </div>
                <div class="flex items-center">
                    <div class="w-1/2 pr-12"></div>
                    <div class="w-12 h-12 bg-indigo-600 rounded-full flex items-center justify-center text-white font-bold z-10 relative flex-shrink-0 text-sm">2024</div>
                    <div class="w-1/2 pl-12">
                        <div class="p-8 rounded-3xl bg-white shadow-lg border border-slate-100">
                            <h4 class="text-2xl font-bold text-slate-900 mb-2">50K+ Collection</h4>
                            <p class="text-slate-600">Reached 50,000 books milestone with 12,000+ active members across multiple cities.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Mobile Timeline -->
        <div class="d-md-none">
            <div class="position-relative ps-4" style="border-left: 3px solid #e0e7ff">
                @foreach (var item in new[] {
                    new { year = "2020", title = "Foundation", desc = "Started with 500 books in a small rented space, driven by passion for knowledge sharing." },
                    new { year = "2021", title = "Digital Transformation", desc = "Launched our online catalog system, making books accessible 24/7 to all members." },
                    new { year = "2022", title = "Expansion", desc = "Moved to a larger facility with 10,000+ books and dedicated study spaces." },
                    new { year = "2024", title = "50K+ Collection", desc = "Reached 50,000 books milestone with 12,000+ active members across multiple cities." }
                })
                {
                    <div class="mb-6 position-relative">
                        <div class="position-absolute" style="left: -1.6rem; top: 0.25rem; width: 1rem; height: 1rem; background: #6366f1; border-radius: 50%;"></div>
                        <div class="p-4 rounded-3 bg-white shadow-sm border border-slate-100">
                            <span class="badge bg-indigo-600 text-white mb-2">@item.year</span>
                            <h5 class="font-bold text-slate-900 mb-1">@item.title</h5>
                            <p class="text-slate-600 text-sm mb-0">@item.desc</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- Team -->
