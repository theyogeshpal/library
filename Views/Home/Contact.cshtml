@{
    Layout = "_WebLayout";
}

<section class="py-16 py-lg-32 bg-slate-50">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-5">
                <div class="p-12 rounded-4xl bg-indigo-600 text-white shadow-2xl shadow-indigo-200">
                    <h2 class="text-4xl font-black mb-10">Get in Touch</h2>
                    <p class="text-xl opacity-80 mb-12">Have questions about our collection or services? Our team is here to help you navigate your learning journey.</p>
                    <div class="space-y-10">
                        <div class="flex items-start gap-6">
                            <div class="w-12 h-12 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 text-xl">
                                <i class="fas fa-map-marker-alt"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-xl mb-2">Campus Location</h4>
                                <p class="opacity-70">123 Knowledge St, Education City<br>UP, India - 201010</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-6">
                            <div class="w-12 h-12 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 text-xl">
                                <i class="fas fa-phone-alt"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-xl mb-2">Support Line</h4>
                                <p class="opacity-70">+91 7817095043<br>Mon-Fri, 9am - 6pm</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-6">
                            <div class="w-12 h-12 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 text-xl">
                                <i class="fas fa-envelope"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-xl mb-2">General Inquiry</h4>
                                <p class="opacity-70">info@riskflight.com<br>support@riskflight.com</p>
                            </div>
                        </div>
                    </div>
                    <div class="mt-20">
                        <h4 class="font-bold mb-6">Connect with us</h4>
                        <div class="flex gap-4">
                            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors cursor-pointer"><i class="fab fa-facebook-f"></i></div>
                            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors cursor-pointer"><i class="fab fa-twitter"></i></div>
                            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors cursor-pointer"><i class="fab fa-instagram"></i></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="p-12 rounded-4xl bg-white border border-slate-100 shadow-xl h-100">
                    <h3 class="text-3xl font-black text-slate-900 mb-8">Send us a Message</h3>
                    <form class="row g-4">
                        <div class="col-md-6">
                            <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-widest">Full Name</label>
                            <input type="text" class="w-full px-6 py-4 rounded-2xl bg-slate-50 border-0 focus:ring-2 focus:ring-indigo-500 transition-all" placeholder="Yogesh Pal">
                        </div>
                        <div class="col-md-6">
                            <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-widest">Email Address</label>
                            <input type="email" class="w-full px-6 py-4 rounded-2xl bg-slate-50 border-0 focus:ring-2 focus:ring-indigo-500 transition-all" placeholder="yogesh@example.com">
                        </div>
                        <div class="col-12">
                            <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-widest">Inquiry Type</label>
                            <select class="w-full px-6 py-4 rounded-2xl bg-slate-50 border-0 focus:ring-2 focus:ring-indigo-500 transition-all">
                                <option>Membership Question</option>
                                <option>Book Availability</option>
                                <option>Donation Program</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-widest">Your Message</label>
                            <textarea class="w-full px-6 py-4 rounded-2xl bg-slate-50 border-0 focus:ring-2 focus:ring-indigo-500 transition-all min-h-[150px]" placeholder="How can we help you today?"></textarea>
                        </div>
                        <div class="col-12 pt-4">
                            <button type="button" class="btn-premium w-full text-lg">Send Inquiry Successfully</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="h-[500px] w-full bg-slate-200 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-indigo-600/20 to-purple-600/20"></div>
    <div class="w-full h-full flex items-center justify-center text-slate-600 relative z-10">
        <div class="text-center p-12 bg-white/80 backdrop-blur-sm rounded-4xl shadow-2xl">
            <i class="fas fa-map-marked-alt text-7xl mb-6 text-indigo-600"></i>
            <h3 class="font-bold text-2xl mb-2">Visit Us</h3>
            <p class="text-slate-500">123 Knowledge St, Education City, UP - 201010</p>
            <button class="mt-6 px-6 py-3 bg-indigo-600 text-white font-bold rounded-xl hover:bg-indigo-700 transition-colors">
                <i class="fas fa-directions me-2"></i>Get Directions
            </button>
        </div>
    </div>
</section>

<section class="py-20 bg-white">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="p-8 rounded-3xl bg-gradient-to-br from-indigo-50 to-purple-50 border border-indigo-100 text-center hover:shadow-xl transition-all">
                    <div class="w-16 h-16 bg-indigo-600 rounded-2xl flex items-center justify-center text-2xl text-white mx-auto mb-4">
                        <i class="fas fa-headset"></i>
                    </div>
                    <h4 class="font-bold text-xl mb-2">24/7 Support</h4>
                    <p class="text-slate-600 text-sm">Our team is always ready to help you</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-8 rounded-3xl bg-gradient-to-br from-indigo-50 to-purple-50 border border-indigo-100 text-center hover:shadow-xl transition-all">
                    <div class="w-16 h-16 bg-indigo-600 rounded-2xl flex items-center justify-center text-2xl text-white mx-auto mb-4">
                        <i class="fas fa-clock"></i>
                    </div>
                    <h4 class="font-bold text-xl mb-2">Quick Response</h4>
                    <p class="text-slate-600 text-sm">We reply within 2 hours on average</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-8 rounded-3xl bg-gradient-to-br from-indigo-50 to-purple-50 border border-indigo-100 text-center hover:shadow-xl transition-all">
                    <div class="w-16 h-16 bg-indigo-600 rounded-2xl flex items-center justify-center text-2xl text-white mx-auto mb-4">
                        <i class="fas fa-user-friends"></i>
                    </div>
                    <h4 class="font-bold text-xl mb-2">Expert Team</h4>
                    <p class="text-slate-600 text-sm">Experienced professionals at your service</p>
                </div>
            </div>
        </div>
    </div>
</section>
