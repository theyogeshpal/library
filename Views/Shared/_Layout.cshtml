<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Librarian Dashboard</title>
    <link rel="shortcut icon" href="./Images/book-2478.gif" type="image/x-icon">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.0/css/all.min.css" integrity="sha512-DxV+EoADOkOygM4IR9yXP8Sb2qwgidEmeqAEmDKIOfPRQZOWbXCzLC6vjbZyy0vPisbH2SyW27+ddLVCN+OMzQ==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background: linear-gradient(to right, #2fb4b4, #ffffff);
        }

        .icons {
            display: flex;
            flex-direction: column;
            justify-content: start;
            align-items: center;
            gap: 3rem;
            padding: 4rem 0;
            color: gray;
        }

            .icons a {
                color: gray;
            }

            .icons div:hover {
                transform: scale(1.1);
                transition: all 0.1s ease-in-out;
                background-color: rgb(251, 251, 251);
                color: black;
            }

            .icons div:hover {
                color: black;
            }

                .icons div:hover .icoi {
                    color: black;
                }

        .box:hover {
            transform: translateY(-15px);
            box-shadow: 0px 0px 15px rgb(255, 255, 255);
            transition: all 0.2s ease-in-out;
        }

        .ic {
            font-size: 2rem;
        }

        .username {
            font-size: 1rem;
        }

        .box:hover .z {
            transform: rotateY(360deg) scale(1.1);
            color: purple;
            transition: all 0.5s ease;
        }

        .iic {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .book-list:hover {
            background-color: rgb(244, 194, 194);
            transform: scale(1.002);
            transition: all 0.2s ease;
        }

        .tabl {
            overflow-x: auto;
            overflow-y: hidden;
        }

        .ico {
            color: rgba(255, 255, 255, 0.5);
        }

        .pr-cl-btn {
            position: absolute;
            left: 340px;
            top: 40px;
        }

        .pp {
            position: absolute;
            margin-top: -75px;
            z-index: 99;
            border: 5px solid rgb(255, 255, 255);
        }
        @@media (max-width:570px) {
            .dash

        {
            display: none;
            background-color: red;
        }

        .icons {
            display: flex;
            flex-direction: row;
            justify-content: center;
            align-items: center;
            gap: 1rem;
            padding: 1rem 0;
        }

        .ic {
            font-size: 1rem;
        }

        .username {
            font-size: 0.8rem;
        }

        .bel {
            display: none;
        }

        .userdesignation {
            font-size: 0.8rem;
        }

        .iic {
            display: none;
        }

        .pr-cl-btn {
            position: absolute;
            left: 265px;
            top: 30px;
        }

        }
    </style>
</head>
<body class="bg-light">
    <div class="container-fluid">
        <!-- navbar open -->
        <div class="row">
            <div class="col-sm-12 p-0" >
                <nav class=" d-flex p-2 justify-content-between align-items-center">
                    <!-- Logo  -->
                    <div class=" fs-1 fw-bold px-2 d-flex  justify-content-between align-items-center">
                        <p class=" p-0 m-0" style="font-family:Georgia, 'Times New Roman', Times, serif;">RiskFlight</p>

                    </div>
                    <!-- dashboard -->
                    <div class="fs-1 dash fw-bold text-end w-25">
                        Dashboard
                    </div>



                    <!-- account open -->
                    <div class="d-flex justify-content-center">

                        <div class="d-flex w-100 justify-content-center gap-2">
                            <div class="d-flex flex-column justify-content-center">
                                <p class="m-0 username text-end fw-bold p-0">Yogesh Pal</p>
                                <p class="m-0 userdesignation text-end text-secondary p-0">Librarian</p>
                            </div>

                            <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar" aria-controls="offcanvasNavbar" aria-label="Toggle navigation">
                                <span class="align-content-center">
                                    <img class=" rounded-circle mx-2" src="https://images.pexels.com/photos/14653174/pexels-photo-14653174.jpeg" alt="" style="height: 2.5rem; width: 2.5rem;">
                                </span>
                            </button>
                            <div class="offcanvas offcanvas-end p-0 m-0 bg-light" tabindex="-1" id="offcanvasNavbar" aria-labelledby="offcanvasNavbarLabel">
                                <div class="offcanvas-header m-0 p-0 z-0">
                                    <img src="https://img.freepik.com/free-vector/space-banner-with-purple-planet-landscape_107791-6230.jpg?semt=ais_incoming&w=740&q=80" alt="" class="rounded-bottom-5 w-100 z-0 overflow-hidden">
                                    <button type="button" class="btn-close pr-cl-btn position-absolute bg-white text-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                                </div>
                                <div class="offcanvas-body m-0 z-3">
                                    <div class="align-content-center bg-primary d-flex justify-content-center w-100">
                                        <img class=" rounded-circle pp mx-2" src="https://images.pexels.com/photos/14653174/pexels-photo-14653174.jpeg" alt="" style="height: 8rem; width: 8rem;">
                                    </div>
                                    <div class="mt-5 fw-bold fs-1 text-center mb-0 pb-0 pt-2">Yogesh Pal</div>
                                    <div class="fst-italic fs-6 text-center m-0">Librarian</div>
                                    <div class="bg-white shadow-md shadow-gray-500 rounded-5 pr-2 p-3 mt-2">
                                        <ul class="navbar-nav w-100 justify-content-end flex-grow-1">
                                            <li class="nav-item my-1 hover:bg-yellow-300 hover:scale-500 hover:scale-105 transition-all shadow-sm rounded px-2 w-100 nav-link my-1 d-flex justify-content-between">

                                                <span class="fw-bold text-gray-800">Mobile: </span>
                                                <span class=" text-gray-600">+91 7817095043</span>

                                            </li>
                                            <li class="nav-item my-1 hover:bg-yellow-300 hover:scale-500 hover:scale-105 transition-all shadow-sm rounded px-2 w-100 nav-link my-1 d-flex justify-content-between">

                                                <span class="fw-bold text-gray-800">Email: </span>
                                                <span class=" text-gray-600">librarian@gmail.com</span>

                                            </li>
                                            <li class="nav-item my-1 hover:bg-yellow-300 hover:scale-500 hover:scale-105 transition-all shadow-sm rounded px-2 w-100 nav-link my-1 d-flex justify-content-between">

                                                <span class="fw-bold text-gray-800">Gender: </span>
                                                <span class=" text-gray-600">Male</span>

                                            </li>
                                            <li class="nav-item nav-link my-1 d-flex justify-content-between hover:bg-yellow-300 hover:scale-500 hover:scale-105 transition-all shadow-sm rounded px-2 w-100">

                                                <span class="fw-bold text-gray-800">Date of Birth: </span>
                                                <span class=" text-gray-600">13/09/2004</span>

                                            </li>
                                            <li class="nav-item my-1 hover:scale-105 transition-all rounded px-2 w-100 nav-link d-flex justify-content-center">
                                                <a asp-controller="Admin" asp-action="logoutAdmin" class="btn btn-outline-danger" aria-current="page">
                                                    Logout
                                                </a>
                                            </li>



                                        </ul>

                                    </div>
                                    <div class="d-flex mt-4 justify-content-center gap-2">
                                        <a href="#" class="btn btn-primary w-50 fw-bold">Edit Profile</a>
                                        <a href="#" class="btn btn-primary w-50 fw-bold">Add Librarian</a>
                                    </div>
                                </div>


                            </div>
                            <!-- account close -->


                </nav>
            </div>
        </div>
        <!-- navbar close -->
        <!-- main page open -->
        <div class="row" >
            <div class="col-sm-1 m-0 icons">
                <!-- background-color: rgb(50, 50, 55); -->
                <div class="p-1 ico rounded-3">
                    <a asp-action="Index">
                        <button type="button" class="btn ico p-1 py-1 bg-transparent"
                                data-bs-toggle="tooltip"
                                data-bs-placement="top"
                                data-bs-custom-class="custom-tooltip"
                                data-bs-title="Dashboard">
                            <i class="fa-solid fa-grip icoi" style="font-size: 6vmin;"></i>

                        </button>
                    </a>
                </div>

                <div class="rounded-3">
                    <a asp-action="issuedbook">
                        <button type="button" class="btn ico p-1 py-2 bg-transparent"
                                data-bs-toggle="tooltip"
                                data-bs-placement="top"
                                data-bs-custom-class="custom-tooltip"
                                data-bs-title="Issue Book">
                            <i class="fa-solid icoi fa-book" style="font-size: 6vmin;"></i>

                        </button>
                    </a>
                </div>
                <div class="rounded-3">
                    <a asp-action="TotalAddBook">
                        <button type="button" class="btn ico p-1 py-2 bg-transparent "
                                data-bs-toggle="tooltip"
                                data-bs-placement="top"
                                data-bs-custom-class="custom-tooltip"
                                data-bs-title="Total Book">
                            <i class="fa-solid icoi fa-book-open-reader" style="font-size: 6vmin;"></i>

                        </button>
                    </a>
                </div>
                <div class="rounded-3">
                    <a asp-action="OverDueData">
                        <button type="button" class="btn ico p-1 py-2 bg-transparent "
                                data-bs-toggle="tooltip"
                                data-bs-placement="top"
                                data-bs-custom-class="custom-tooltip"
                                data-bs-title="Overdue Books">
                            <i class="fa-solid icoi fa-hourglass" style="font-size: 6vmin;"></i>

                        </button>
                    </a>
                </div>

            </div>
            <div  class="col-sm-11  py-5 main-c ico  shadow-xl shadow-gray-900 text-dark" style="border-top-left-radius: 20px;background: linear-gradient(90deg, #5ee7df, #b490ca);min-height:89vh;">

                @RenderBody()
            </div>
            
        </div>
        <!-- main page close -->
    </div>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script>
        const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]')
        const tooltipList = [...tooltipTriggerList].map(tooltipTriggerEl => new bootstrap.Tooltip(tooltipTriggerEl))
    </script>
</body>
</html>