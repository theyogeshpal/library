
@{
    Layout = "_Layout";
}

@* model open *@
<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title text-center fs-4" id="exampleModalLabel">Add Book</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form method="post" asp-action="issuebook">
                    <label for="" class="fs-5 my-1 fw-bold text-dark">Enter Book ID:</label>
                    <input type="text" name="bookid" class="form-control" placeholder="Enter Book ID" id="" required>

                    <label for="" class="fs-5 my-1 fw-bold text-dark">Borrower Name:</label>
                    <input type="text" name="stuname" class="form-control" placeholder="Enter Author Name" id="" required>

                    <label for="" class="fs-5 my-1 fw-bold text-dark">Mobile Number:</label>
                    <input type="number" name="mobile" max="9999999999" min="1000000000" class="form-control" placeholder="Mobile Number" id="" required>
                    <label for="" class="fs-5 my-1 fw-bold text-dark">Issuing Date:</label>
                    <input type="text" name="issuedate" class="form-control" id="todaydate" disabled>
                    <label for="" class="fs-5 my-1 fw-bold text-dark">Due Date:</label>
                    <input type="text" pattern="\d{2}-\d{2}-\d{4}" name="duedate" placeholder="DD-MM-YYYY" class="form-control">
                    <br>
                    <button type="submit" class="form-control btn btn-primary">Add Book</button>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>


            </div>
        </div>
    </div>
</div>


@* model close *@

<div class="w-100 mb-5 px-4 d-flex gap-5 justify-content-evenly flex-wrap">
    <p class="text-center w-100"></p>
    <div class=" p-3 p-0 m-0 rounded-4 bg-white d-flex flex-wrap flex-column w-100" style=" background-color: rgb(76, 76, 83);">
        <div class="d-flex w-100 align-items-center justify-content-between">
            <h1 class=""><i class="fa-solid fa-file"></i>Issued Book</h1>
            <button id="issuebtn" type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#exampleModal">
                Issue Book
            </button>
        </div>

        <div class="w-100 tabl">

            <table class="bordered my-2 w-100">
                <tr class="bg-danger  text-black bg-opacity-25" style="border: 2px solid rgb(111, 108, 108);">
                    <th class="text-center p-2" style="border: 2px solid rgb(111, 108, 108);">Book ID</th>
                    <th class="text-center p-2" style="border: 2px solid rgb(111, 108, 108);">Borrower Name</th>
                    <th class="text-center p-2" style="border: 2px solid rgb(111, 108, 108);">Borrower Mobile</th>
                    <th class="text-center p-2" style="border: 2px solid rgb(111, 108, 108);">Book Name</th>
                    <th class="text-center p-2" style="border: 2px solid rgb(111, 108, 108);">Author</th>
                    <th class="text-center p-2" style="border: 2px solid rgb(111, 108, 108);">Issue Date</th>
                    <th class="text-center p-2" style="border: 2px solid rgb(111, 108, 108);">Due Date</th>
                    <th class="text-center p-2" style="border: 2px solid rgb(111, 108, 108);">Return Status</th>
                    <th class="text-center p-2" style="border: 2px solid rgb(111, 108, 108);">Return Status</th>
                    <th class="text-center p-2" style="border: 2px solid rgb(111, 108, 108);">Return Status</th>
                </tr>

             
                    <tr class="hover:bg-red-200" style="border: 2px solid rgb(111, 108, 108);">
                        <td class="text-center px-0"></td>
                        <td class="text-center px-0"></td>
                        <td class="text-center px-0"></td>
                        <td class="text-center px-0"></td>
                        <td class="text-center px-0"></td>
                        <td class="text-center px-0"></td>
                        <td class="text-center px-0"></td>
                        <td class="text-center px-0"></td>
                        <td class="text-center px-0"></td>
                        <td class="text-center px-0"></td>
                        @* <td class="text-center">
                            @if (row["status"].ToString() == "True")
                            {
                                <a class=" btn btn-success bg-opacity-100 text-white bg-green-700 rounded-pill">
                                    Returned
                                </a>
                            }
                            else
                            {
                                <a asp-action="returned" asp-route-id="@row["bookid"]" class=" btn btn-outline-secondary rounded-pill" onclick="return confirm('Please Make Sure that you have collected the Book.') ">
                                    Pending
                                </a>
                            }


                        </td> *@
                    </tr>
                


            </table>
        </div>


    </div>

</div>




<script>
    const todaydate = document.querySelector('input[name="issuedate"]');
    const date = todaydate.value;
    const btn = document.getElementById('issuebtn');
      btn.addEventListener("click", () => {
      const today = new Date();
      const day = String(today.getDate()).padStart(2, '0');
      const month = String(today.getMonth() + 1).padStart(2, '0'); // Month is 0-indexed
      const year = today.getFullYear();


        todaydate.value = `${day}-${month}-${year}`;

        console.log(todaydate.value);
    })

    // Example usage:
     // Outputs "09/08/2025" (MM/DD/YYYY)

</script>