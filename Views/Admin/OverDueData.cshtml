@model System.Data.DataTable

@{
    Layout = "_AdminLayout";
}

<div class="mb-8 flex justify-between items-end">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Overdue Analysis</h1>
        <p class="text-slate-500 font-medium pt-1">Books that have exceeded their return deadline.</p>
    </div>
    @if (Model != null && Model.Rows.Count > 0)
    {
        <div class="flex items-center gap-2 px-4 py-2 bg-red-50 border border-red-100 rounded-xl text-red-600 font-bold text-sm">
            <i class="fas fa-exclamation-triangle"></i> @Model.Rows.Count Overdue Item(s)
        </div>
    }
</div>

@if (Model == null || Model.Rows.Count == 0)
{
    <div class="premium-table-card flex flex-col items-center justify-center text-center p-20">
        <div class="w-24 h-24 rounded-full bg-green-50 text-green-500 flex items-center justify-center text-4xl mb-6">
            <i class="fas fa-check-double"></i>
        </div>
        <h2 class="text-2xl font-black text-slate-900 mb-2">Zero Overdue Items</h2>
        <p class="text-slate-500 max-w-md mx-auto">All issued books are within their due dates or have been returned.</p>
        <a asp-action="issuedbook" class="mt-6 px-6 py-3 bg-indigo-600 text-white font-bold rounded-xl no-underline hover:bg-indigo-700 transition-colors">
            View Issue History
        </a>
    </div>
}
else
{
    <div class="premium-table-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider">Book ID</th>
                        <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider">Borrower Info</th>
                        <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider">Book Name</th>
                        <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider text-center">Due Date</th>
                        <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider text-center">Days Overdue</th>
                        <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider text-end">Fine (₹10/day)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (System.Data.DataRow row in Model.Rows)
                    {
                        int daysOverdue = 0;
                        string fineText = "N/A";
                        try
                        {
                            DateTime dueDate = DateTime.Parse(row["duedate"].ToString());
                            daysOverdue = (DateTime.Today - dueDate).Days;
                            if (daysOverdue < 0) daysOverdue = 0;
                            fineText = "₹" + (daysOverdue * 10).ToString();
                        }
                        catch { }

                        <tr>
                            <td class="px-4 py-3">
                                <span class="bg-red-50 text-red-700 font-mono text-xs px-2 py-1 rounded">@row["bookid"]</span>
                            </td>
                            <td class="px-4 py-3">
                                <div class="font-bold text-slate-900">@row["stuname"]</div>
                                <div class="text-[10px] text-slate-400 font-bold">
                                    <i class="fas fa-phone me-1"></i>@row["stumobile"]
                                </div>
                            </td>
                            <td class="px-4 py-3">
                                <div class="text-sm font-bold text-slate-700">@row["bookname"]</div>
                                <div class="text-[11px] text-slate-400">by @row["author"]</div>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="text-xs font-bold text-red-500 bg-red-50 px-3 py-1 rounded-full border border-red-100">
                                    <i class="fas fa-calendar-times me-1"></i>@row["duedate"]
                                </span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                @if (daysOverdue > 0)
                                {
                                    <span class="text-sm font-black text-red-600 bg-red-50 px-3 py-1 rounded-full">
                                        @daysOverdue days
                                    </span>
                                }
                                else
                                {
                                    <span class="text-xs text-slate-400">—</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-end">
                                <span class="font-black text-red-600">@fineText</span>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="bg-slate-50">
                    <tr>
                        <td colspan="5" class="px-4 py-3 text-end font-bold text-slate-700">Total Fine Pending:</td>
                        <td class="px-4 py-3 text-end font-black text-red-600 text-lg">
                            @{
                                int totalFine = 0;
                                foreach (System.Data.DataRow r in Model.Rows)
                                {
                                    try
                                    {
                                        DateTime d = DateTime.Parse(r["duedate"].ToString());
                                        int days = (DateTime.Today - d).Days;
                                        if (days > 0) totalFine += days * 10;
                                    }
                                    catch { }
                                }
                            }
                            ₹@totalFine
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
}
