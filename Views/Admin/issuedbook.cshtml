@model System.Data.DataTable

@{
    Layout = "_AdminLayout";
}

<div class="mb-8 flex justify-between items-end">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Issue History</h1>
        <p class="text-slate-500 font-medium pt-1">Track book distributions and return statuses.</p>
    </div>
    <button id="issuebtn" type="button" class="btn-premium bg-secondary text-white btn no-underline flex items-center gap-2" data-bs-toggle="modal" data-bs-target="#issueBookModal">
        <i class="fas fa-hand-holding-heart"></i> Issue New Book
    </button>
</div>

@if (TempData["issuedpage"] != null)
{
    <div class="alert alert-indigo border-0 shadow-sm rounded-xl mb-6 bg-indigo-50 text-indigo-700 animate__animated animate__fadeIn">
        <i class="fas fa-info-circle me-2"></i> @TempData["issuedpage"]
    </div>
}

<!-- Issue Modal -->
<div class="modal fade" id="issueBookModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-2xl rounded-3xl overflow-hidden">
            <div class="modal-header bg-slate-900 text-white border-0 py-4 px-6">
                <h5 class="modal-title font-bold text-xl"><i class="fas fa-paper-plane me-2"></i> Issue Book</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-6">
                <form method="post" asp-action="issuebook" class="space-y-4">
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Book ID</label>
                        <input type="text" name="bookid" class="w-full px-4 py-3 rounded-xl bg-slate-100 border-0 focus:ring-2 focus:ring-indigo-500 transition-all outline-none" placeholder="Enter Book ID" required>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Borrower Name</label>
                        <input type="text" name="stuname" class="w-full px-4 py-3 rounded-xl bg-slate-100 border-0 focus:ring-2 focus:ring-indigo-500 transition-all outline-none" placeholder="Student/Teacher Name" required>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Mobile Number</label>
                        <input type="number" name="mobile" max="9999999999" min="1000000000" class="w-full px-4 py-3 rounded-xl bg-slate-100 border-0 focus:ring-2 focus:ring-indigo-500 transition-all outline-none" placeholder="10 Digit Mobile" required>
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Issue Date</label>
                            <input type="text" name="issuedate" class="w-full px-4 py-3 rounded-xl bg-slate-200 border-0 font-bold text-slate-600 outline-none" id="todaydate" readonly>
                        </div>
                        <div class="col-6">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Due Date</label>
                            <input type="date" name="duedate" id="duedatepicker" class="w-full px-4 py-3 rounded-xl bg-slate-100 border-0 focus:ring-2 focus:ring-indigo-500 transition-all outline-none" required>
                        </div>
                    </div>
                    <div class="pt-4 flex gap-3">
                        <button type="button" class="btn btn-light w-full py-3 rounded-xl font-bold" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn-premium w-full py-3 rounded-xl">Confirm Issue</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="premium-table-card mb-4 py-4">
    <input type="text" id="issueSearch" placeholder="Filter by borrower name, book name or book ID..."
           class="w-full px-4 py-2 rounded-xl bg-slate-100 border-0 focus:ring-2 focus:ring-indigo-500 outline-none transition-all"
           onkeyup="filterIssueTable()">
</div>

<div class="premium-table-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-slate-50">
                <tr>
                    <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider">Book ID</th>
                    <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider">Borrower Details</th>
                    <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider">Book Name & Author</th>
                    <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider text-center">Dates</th>
                    <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider text-end">Status</th>
                </tr>
            </thead>
            <tbody id="issueTableBody">
                @foreach (System.Data.DataRow row in Model.Rows)
                {
                    <tr>
                        <td class="px-4 py-3">
                            <span class="bg-slate-100 text-slate-700 font-mono text-xs px-2 py-1 rounded">@row["bookid"]</span>
                        </td>
                        <td class="px-4 py-3">
                            <div class="font-bold text-slate-900">@row["stuname"]</div>
                            <div class="text-[10px] text-slate-400 font-bold">M: @row["stumobile"]</div>
                        </td>
                        <td class="px-4 py-3">
                            <div class="text-sm font-bold text-slate-700">@row["bookname"]</div>
                            <div class="text-[11px] text-slate-400">by @row["author"]</div>
                        </td>
                        <td class="px-4 py-3 text-center">
                            <div class="flex flex-col gap-1 items-center">
                                <span class="text-[11px] text-slate-500"><i class="far fa-calendar-alt me-1"></i> @row["issuedate"]</span>
                                <span class="text-[11px] font-bold text-indigo-600"><i class="fas fa-hourglass-half me-1"></i> @row["duedate"]</span>
                            </div>
                        </td>
                        <td class="px-4 py-3 text-end">
                            @if (row["status"].ToString() == "True")
                            {
                                <span class="bg-green-100 text-green-700 text-[10px] px-3 py-1.5 rounded-full font-bold inline-flex items-center gap-1">
                                    <i class="fas fa-check"></i> RETURNED
                                </span>
                            }
                            else
                            {
                                <a asp-action="returned" asp-route-id="@row["bookid"]" 
                                   class="bg-amber-100 text-amber-700 text-[10px] px-3 py-1.5 rounded-full font-bold inline-flex items-center gap-1 no-underline hover:bg-amber-200 transition-colors"
                                   onclick="return confirm('Confirm book return collection?')">
                                    <i class="fas fa-clock"></i> PENDING
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        const todayDateInput = document.getElementById('todaydate');
        const issueBtn = document.getElementById('issuebtn');
        const duePicker = document.getElementById('duedatepicker');

        issueBtn.addEventListener("click", () => {
            const today = new Date();
            const day = String(today.getDate()).padStart(2, '0');
            const month = String(today.getMonth() + 1).padStart(2, '0');
            const year = today.getFullYear();
            todayDateInput.value = `${day}-${month}-${year}`;
            // Set min date for due date picker to today
            duePicker.min = `${year}-${month}-${day}`;
        });

        function filterIssueTable() {
            const query = document.getElementById('issueSearch').value.toLowerCase();
            const rows = document.querySelectorAll('#issueTableBody tr');
            rows.forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(query) ? '' : 'none';
            });
        }
    </script>
}