@model System.Data.DataTable

@{
    Layout = "_AdminLayout";
}

<div class="mb-6 d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-end gap-3">
    <div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-900 tracking-tight">Library Collection</h1>
        <p class="text-slate-500 font-medium pt-1 text-sm">Manage and track all books in the library system.</p>
    </div>
    <button type="button" class="btn-premium no-underline d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#addBookModal">
        <i class="fas fa-plus"></i> Add New Book
    </button>
</div>

@if (TempData["bookadd"] != null)
{
    <div class="alert border-0 shadow-sm rounded-xl mb-6 animate__animated animate__fadeIn @(TempData["bookadd"].ToString().Contains("Error") || TempData["bookadd"].ToString().Contains("already") ? "alert-danger" : "alert-success")">
        <i class="fas fa-info-circle me-2"></i> @TempData["bookadd"]
    </div>
}

<!-- Search Bar -->
<div class="premium-table-card mb-4 py-4">
    <form asp-action="SearchBooks" method="get" class="flex gap-3">
        <input type="text" name="query" value="@ViewBag.SearchQuery" placeholder="Search by title, author or book ID..."
               class="flex-1 px-4 py-2 rounded-xl bg-slate-100 border-0 focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
        <button type="submit" class="px-5 py-2 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700 transition-colors">
            <i class="fas fa-search me-2"></i>Search
        </button>
        @if (ViewBag.SearchQuery != null)
        {
            <a asp-action="TotalAddBook" class="px-5 py-2 bg-slate-200 text-slate-700 rounded-xl font-bold hover:bg-slate-300 transition-colors no-underline">
                <i class="fas fa-times me-2"></i>Clear
            </a>
        }
    </form>
</div>

<!-- Add Book Modal -->
<div class="modal fade" id="addBookModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-2xl rounded-3xl overflow-hidden">
            <div class="modal-header bg-slate-900 text-white border-0 py-4 px-6">
                <h5 class="modal-title font-bold text-xl"><i class="fas fa-book-medical me-2"></i> Add New Book</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-6">
                <form method="post" asp-action="Addbook" class="space-y-4">
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Unique Book ID</label>
                        <input type="text" name="bookid" class="w-full px-4 py-3 rounded-xl bg-slate-100 border-0 focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="e.g. BK-1001" required>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Book Title</label>
                        <input type="text" name="bookname" class="w-full px-4 py-3 rounded-xl bg-slate-100 border-0 focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="Enter full title" required>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Author Name</label>
                        <input type="text" name="author" class="w-full px-4 py-3 rounded-xl bg-slate-100 border-0 focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="Enter author name" required>
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Total Copies</label>
                            <input type="number" name="copy" min="1" class="w-full px-4 py-3 rounded-xl bg-slate-100 border-0 focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="0" required>
                        </div>
                        <div class="col-6">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Available</label>
                            <input type="number" name="available" min="0" class="w-full px-4 py-3 rounded-xl bg-slate-100 border-0 focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="0" required>
                        </div>
                    </div>
                    <div class="pt-4 flex gap-3">
                        <button type="button" class="btn btn-light w-full py-3 rounded-xl font-bold" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn-premium w-full py-3 rounded-xl">Register Book</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Edit Book Modal -->
<div class="modal fade" id="editBookModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-2xl rounded-3xl overflow-hidden">
            <div class="modal-header bg-indigo-600 text-white border-0 py-4 px-6">
                <h5 class="modal-title font-bold text-xl"><i class="fas fa-edit me-2"></i> Edit Book</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-6">
                <form method="post" asp-action="EditBook" class="space-y-4">
                    <input type="hidden" name="editid" id="editid">
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Book Title</label>
                        <input type="text" name="editbookname" id="editbookname" class="w-full px-4 py-3 rounded-xl bg-slate-100 border-0 focus:ring-2 focus:ring-indigo-500 outline-none" required>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Author Name</label>
                        <input type="text" name="editauthor" id="editauthor" class="w-full px-4 py-3 rounded-xl bg-slate-100 border-0 focus:ring-2 focus:ring-indigo-500 outline-none" required>
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Total Copies</label>
                            <input type="number" name="editcopy" id="editcopy" min="1" class="w-full px-4 py-3 rounded-xl bg-slate-100 border-0 focus:ring-2 focus:ring-indigo-500 outline-none" required>
                        </div>
                        <div class="col-6">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Available</label>
                            <input type="number" name="editavailable" id="editavailable" min="0" class="w-full px-4 py-3 rounded-xl bg-slate-100 border-0 focus:ring-2 focus:ring-indigo-500 outline-none" required>
                        </div>
                    </div>
                    <div class="pt-4 flex gap-3">
                        <button type="button" class="btn btn-light w-full py-3 rounded-xl font-bold" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn-premium w-full py-3 rounded-xl" style="background: linear-gradient(135deg,#6366f1,#a855f7)">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="premium-table-card">
    <div class="flex justify-between items-center mb-4">
        <p class="text-sm text-slate-500 font-semibold">Total: <span class="text-slate-900 font-bold">@Model.Rows.Count</span> books</p>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-slate-50">
                <tr>
                    <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider">Sr.</th>
                    <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider">Book ID</th>
                    <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider">Title & Author</th>
                    <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider text-center">Copies</th>
                    <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider text-center">Available</th>
                    <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (System.Data.DataRow row in Model.Rows)
                {
                    <tr>
                        <td class="px-4 py-3 font-semibold text-slate-600">@row["id"]</td>
                        <td class="px-4 py-3"><span class="bg-indigo-50 text-indigo-700 font-mono text-xs px-2 py-1 rounded">@row["bookID"]</span></td>
                        <td class="px-4 py-3">
                            <div class="font-bold text-slate-900">@row["title"]</div>
                            <div class="text-xs text-slate-500">by @row["author"]</div>
                        </td>
                        <td class="px-4 py-3 text-center font-medium">@row["copies"]</td>
                        <td class="px-4 py-3 text-center">
                            @if (Convert.ToInt32(row["available"]) > 0)
                            {
                                <div class="flex flex-col items-center">
                                    <span class="text-xs font-bold text-green-600 mb-1">@row["available"] Left</span>
                                    <div class="w-16 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                        <div class="bg-green-500 h-full rounded-full" style="width: @(Convert.ToInt32(row["available"]) * 100 / Math.Max(Convert.ToInt32(row["copies"]), 1))%"></div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <span class="bg-red-50 text-red-600 text-[10px] px-2 py-1 rounded-full font-bold uppercase">Out of Stock</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-end">
                            <div class="flex justify-end gap-2">
                                <button class="w-8 h-8 rounded-lg bg-indigo-50 text-indigo-500 hover:bg-indigo-100 transition-all"
                                        onclick="openEditModal('@row["id"]','@row["title"]','@row["author"]','@row["copies"]','@row["available"]')"
                                        data-bs-toggle="modal" data-bs-target="#editBookModal">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <a asp-action="DeleteBook" asp-route-id="@row["id"]"
                                   onclick="return confirm('Delete this book permanently?')"
                                   class="w-8 h-8 rounded-lg bg-red-50 text-red-400 hover:bg-red-100 hover:text-red-600 transition-all flex items-center justify-center no-underline">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function openEditModal(id, title, author, copies, available) {
            document.getElementById('editid').value = id;
            document.getElementById('editbookname').value = title;
            document.getElementById('editauthor').value = author;
            document.getElementById('editcopy').value = copies;
            document.getElementById('editavailable').value = available;
        }
    </script>
}
