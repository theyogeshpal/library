@model LibraryManagementSystem.Models.DashboardModel

@{
    Layout = "_AdminLayout";
}

<div class="mb-6 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2">
    <div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-900 tracking-tight">Overview</h1>
        <p class="text-slate-500 font-medium pt-1 text-sm">Welcome back! Here's what's happening today.</p>
    </div>
    <div class="text-xs text-slate-400 font-semibold">
        <i class="fas fa-calendar-alt me-2"></i>@DateTime.Now.ToString("ddd, dd MMM yyyy")
    </div>
</div>

<!-- Stats Grid -->
<div class="row g-4 mb-10">
    <div class="col-xl-3 col-md-6">
        <div class="stat-card group">
            <div class="flex justify-between items-start mb-4">
                <div class="w-12 h-12 rounded-2xl bg-indigo-50 text-indigo-600 flex items-center justify-center text-xl group-hover:scale-110 transition-transform">
                    <i class="fas fa-book"></i>
                </div>
                <div class="text-xs font-bold text-indigo-500 bg-indigo-50 px-2 py-1 rounded-lg">Live</div>
            </div>
            <div class="text-3xl font-black text-slate-900 mb-1">@ViewBag.Issuecount</div>
            <div class="text-slate-500 text-sm font-semibold uppercase tracking-wider">Books Issued</div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="stat-card group">
            <div class="flex justify-between items-start mb-4">
                <div class="w-12 h-12 rounded-2xl bg-emerald-50 text-emerald-600 flex items-center justify-center text-xl group-hover:scale-110 transition-transform">
                    <i class="fas fa-layer-group"></i>
                </div>
                <div class="text-xs font-bold text-emerald-500 bg-emerald-50 px-2 py-1 rounded-lg">Total</div>
            </div>
            <div class="text-3xl font-black text-slate-900 mb-1">@ViewBag.Totalbook</div>
            <div class="text-slate-500 text-sm font-semibold uppercase tracking-wider">Total Collection</div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="stat-card group">
            <div class="flex justify-between items-start mb-4">
                <div class="w-12 h-12 rounded-2xl bg-red-50 text-red-500 flex items-center justify-center text-xl group-hover:scale-110 transition-transform">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                @if (Convert.ToInt32(ViewBag.OverdueCount) > 0)
                {
                    <div class="text-xs font-bold text-red-500 bg-red-50 px-2 py-1 rounded-lg">Action Needed</div>
                }
                else
                {
                    <div class="text-xs font-bold text-green-500 bg-green-50 px-2 py-1 rounded-lg">All Clear</div>
                }
            </div>
            <div class="text-3xl font-black text-slate-900 mb-1">@ViewBag.OverdueCount</div>
            <div class="text-slate-500 text-sm font-semibold uppercase tracking-wider">Overdue Items</div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="stat-card group">
            <div class="flex justify-between items-start mb-4">
                <div class="w-12 h-12 rounded-2xl bg-purple-50 text-purple-600 flex items-center justify-center text-xl group-hover:scale-110 transition-transform">
                    <i class="fas fa-users"></i>
                </div>
                <div class="text-xs font-bold text-purple-500 bg-purple-50 px-2 py-1 rounded-lg">Staff</div>
            </div>
            <div class="text-3xl font-black text-slate-900 mb-1">@ViewBag.TotalMembers</div>
            <div class="text-slate-500 text-sm font-semibold uppercase tracking-wider">Librarians</div>
        </div>
    </div>
</div>

<!-- Recent Books Table -->
<div class="premium-table-card mb-8">
    <div class="flex justify-between items-center mb-6">
        <div>
            <h2 class="text-xl font-bold text-slate-900">Recent Books</h2>
            <p class="text-sm text-slate-500">Latest books in the library collection.</p>
        </div>
        <a asp-action="TotalAddBook" class="px-4 py-2 border border-slate-200 rounded-xl text-slate-600 font-bold hover:bg-slate-50 transition-colors no-underline text-sm">
            Manage All <i class="fas fa-arrow-right ms-1"></i>
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-slate-50">
                <tr>
                    <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider">Sr.</th>
                    <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider">Book ID</th>
                    <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider">Title & Author</th>
                    <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider text-center">Copies</th>
                    <th class="px-4 py-3 border-0 text-slate-500 text-xs font-bold uppercase tracking-wider text-center">Available</th>
                </tr>
            </thead>
            <tbody>
                @foreach (System.Data.DataRow row in Model.Books.Rows)
                {
                    <tr>
                        <td class="px-4 py-3 font-semibold text-slate-600">@row["id"]</td>
                        <td class="px-4 py-3"><span class="bg-slate-100 text-slate-700 font-mono text-xs px-2 py-1 rounded">@row["bookID"]</span></td>
                        <td class="px-4 py-3">
                            <div class="font-bold text-slate-900">@row["title"]</div>
                            <div class="text-xs text-slate-500">by @row["author"]</div>
                        </td>
                        <td class="px-4 py-3 text-center font-medium">@row["copies"]</td>
                        <td class="px-4 py-3 text-center">
                            @if (Convert.ToInt32(row["available"]) > 0)
                            {
                                <span class="bg-green-100 text-green-700 text-xs px-2 py-1 rounded-full font-bold">@row["available"] In Stock</span>
                            }
                            else
                            {
                                <span class="bg-red-100 text-red-700 text-xs px-2 py-1 rounded-full font-bold">Out of Stock</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="row g-4">
    <!-- Recent Issues -->
    <div class="col-lg-6">
        <div class="premium-table-card">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-lg font-bold text-slate-900">Recent Issues</h3>
                <a asp-action="issuedbook" class="text-indigo-600 text-sm font-bold no-underline">See All <i class="fas fa-arrow-right ms-1"></i></a>
            </div>
            @if (Model.issuedbooks.Rows.Count == 0)
            {
                <div class="text-center py-10 text-slate-400">
                    <i class="fas fa-book-open text-4xl mb-3"></i>
                    <p class="font-semibold">No books issued yet</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-borderless table-sm align-middle">
                        <thead class="bg-slate-50/50">
                            <tr>
                                <th class="text-xs font-bold text-slate-400 uppercase tracking-widest px-0">Borrower</th>
                                <th class="text-xs font-bold text-slate-400 uppercase tracking-widest">Book</th>
                                <th class="text-xs font-bold text-slate-400 uppercase tracking-widest text-end">Due Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (System.Data.DataRow row1 in Model.issuedbooks.Rows)
                            {
                                <tr>
                                    <td class="py-3 px-0">
                                        <div class="font-bold text-sm">@row1["stuname"]</div>
                                        <div class="text-[10px] text-slate-400">@row1["stumobile"]</div>
                                    </td>
                                    <td class="py-3">
                                        <div class="text-sm truncate max-w-[150px]">@row1["bookname"]</div>
                                    </td>
                                    <td class="py-3 text-end">
                                        <span class="text-xs font-bold text-slate-500">@row1["duedate"]</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Overdue Section -->
    <div class="col-lg-6">
        <div class="premium-table-card h-100">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-lg font-bold text-slate-900">Overdue Books</h3>
                <a asp-action="OverDueData" class="text-red-500 text-sm font-bold no-underline">Full Report <i class="fas fa-arrow-right ms-1"></i></a>
            </div>
            @if (Model.OverdueBooks == null || Model.OverdueBooks.Rows.Count == 0)
            {
                <div class="flex flex-col items-center justify-center text-center py-10">
                    <div class="w-16 h-16 rounded-full bg-green-50 flex items-center justify-center text-green-500 text-2xl mb-4">
                        <i class="fas fa-check-double"></i>
                    </div>
                    <h4 class="font-bold text-slate-900 mb-1">No Overdue Items</h4>
                    <p class="text-sm text-slate-500">All books are within their due dates.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-borderless table-sm align-middle">
                        <thead class="bg-slate-50/50">
                            <tr>
                                <th class="text-xs font-bold text-slate-400 uppercase tracking-widest px-0">Borrower</th>
                                <th class="text-xs font-bold text-slate-400 uppercase tracking-widest">Book</th>
                                <th class="text-xs font-bold text-slate-400 uppercase tracking-widest text-end">Due</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (System.Data.DataRow row2 in Model.OverdueBooks.Rows)
                            {
                                <tr>
                                    <td class="py-3 px-0">
                                        <div class="font-bold text-sm text-red-600">@row2["stuname"]</div>
                                        <div class="text-[10px] text-slate-400">@row2["stumobile"]</div>
                                    </td>
                                    <td class="py-3">
                                        <div class="text-sm truncate max-w-[130px]">@row2["bookname"]</div>
                                    </td>
                                    <td class="py-3 text-end">
                                        <span class="text-xs font-bold text-red-500 bg-red-50 px-2 py-1 rounded-full">@row2["duedate"]</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
