<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RiskFlight | Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Outfit', sans-serif;
            background: #f1f5f9;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-wrapper {
            display: flex;
            width: 900px;
            max-width: 95vw;
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.1);
        }

        /* Left Panel */
        .left-panel {
            flex: 1;
            background: linear-gradient(160deg, #4f46e5, #7c3aed);
            padding: 50px 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            color: white;
        }

        .left-panel .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 40px;
        }

        .left-panel .brand i {
            background: rgba(255,255,255,0.2);
            padding: 8px 10px;
            border-radius: 10px;
        }

        .left-panel h2 {
            font-size: 1.8rem;
            font-weight: 700;
            line-height: 1.3;
            margin-bottom: 16px;
        }

        .left-panel p {
            font-size: 0.95rem;
            opacity: 0.8;
            line-height: 1.6;
            margin-bottom: 40px;
        }

        .stats {
            display: flex;
            gap: 24px;
        }

        .stat-item {
            text-align: center;
        }

        .stat-item .num {
            font-size: 1.4rem;
            font-weight: 700;
        }

        .stat-item .label {
            font-size: 0.75rem;
            opacity: 0.7;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* Right Panel */
        .right-panel {
            flex: 1;
            padding: 50px 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .right-panel h3 {
            font-size: 1.6rem;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 6px;
        }

        .right-panel .subtitle {
            color: #94a3b8;
            font-size: 0.9rem;
            margin-bottom: 32px;
        }

        .form-label {
            font-size: 0.8rem;
            font-weight: 600;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 6px;
        }

        .form-control {
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 0.95rem;
            font-family: 'Outfit', sans-serif;
            color: #1e293b;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
            outline: none;
        }

        .input-icon-wrap {
            position: relative;
        }

        .input-icon-wrap .form-control {
            padding-left: 42px;
        }

        .input-icon-wrap .icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 0.9rem;
        }

        .input-icon-wrap .eye-btn {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #94a3b8;
            cursor: pointer;
            padding: 0;
            font-size: 0.9rem;
        }

        .btn-login {
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 13px;
            font-size: 0.95rem;
            font-weight: 600;
            font-family: 'Outfit', sans-serif;
            width: 100%;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.2s;
            margin-top: 8px;
        }

        .btn-login:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        .error-box {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #dc2626;
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 0.85rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .hint-box {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 0.82rem;
            color: #64748b;
            margin-top: 20px;
        }

        .hint-box span {
            color: #4f46e5;
            font-weight: 600;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: #94a3b8;
            font-size: 0.85rem;
            font-weight: 500;
            text-decoration: none;
            margin-top: 24px;
            transition: color 0.2s;
        }

        .back-link:hover { color: #4f46e5; }

        @@media (max-width: 640px) {
            .left-panel { display: none; }
            .right-panel { padding: 40px 28px; }
        }
    </style>
</head>
<body>
    <div class="login-wrapper">

        <!-- Left Panel -->
        <div class="left-panel">
            <div class="brand">
                <i class="fas fa-book-reader"></i>
                RiskFlight
            </div>
            <h2>Welcome back,<br>Librarian!</h2>
            <p>Sign in to manage your library — books, members, issues, and overdue records all in one place.</p>
            <div class="stats">
                <div class="stat-item">
                    <div class="num">50K+</div>
                    <div class="label">Books</div>
                </div>
                <div class="stat-item">
                    <div class="num">12K+</div>
                    <div class="label">Members</div>
                </div>
                <div class="stat-item">
                    <div class="num">24/7</div>
                    <div class="label">Access</div>
                </div>
            </div>
        </div>

        <!-- Right Panel -->
        <div class="right-panel">
            <h3>Sign In</h3>
            <p class="subtitle">Enter your credentials to access the dashboard</p>

            <form method="post" asp-action="checkLogin">
                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <div class="input-icon-wrap">
                        <i class="fas fa-user icon"></i>
                        <input type="text" name="username" class="form-control" placeholder="Enter your username" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <div class="input-icon-wrap">
                        <i class="fas fa-lock icon"></i>
                        <input type="password" id="pass" name="password" class="form-control pe-5" placeholder="Enter your password" required>
                        <button type="button" class="eye-btn" onclick="togglePassword()">
                            <i id="eye-icon" class="fas fa-eye"></i>
                        </button>
                    </div>
                </div>

                @if (TempData["loginerror"] != null)
                {
                    <div class="error-box mb-3">
                        <i class="fas fa-exclamation-circle"></i>
                        @TempData["loginerror"]
                    </div>
                }

                <button type="submit" class="btn-login">
                    Sign In &nbsp;<i class="fas fa-arrow-right"></i>
                </button>
            </form>

           
        </div>

    </div>

    <script>
        function togglePassword() {
            const p = document.getElementById("pass");
            const icon = document.getElementById("eye-icon");
            p.type = p.type === "password" ? "text" : "password";
            icon.className = p.type === "password" ? "fas fa-eye" : "fas fa-eye-slash";
        }
    </script>
</body>
</html>
