<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.0/css/all.min.css" integrity="sha512-DxV+EoADOkOygM4IR9yXP8Sb2qwgidEmeqAEmDKIOfPRQZOWbXCzLC6vjbZyy0vPisbH2SyW27+ddLVCN+OMzQ==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style>
        body {
            background: linear-gradient(90deg, #5ee7df, #b490ca);
        }

        .showpass input[type="checkbox"] {
            height: 1rem;
            width: 1rem;
        }

        .backbtn {
            height: 15vmin;
            width: 15vmin;
            background-color: rgb(198, 254, 230);
            animation: shadow;
            animation-duration: 1s;
            animation-timing-function: linear;
            animation-iteration-count: infinite;
            font-size: 1.5rem;
        }

        .content {
            width: 50%;
        }

        form {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            width: 100%;
        }

        .main {
            box-shadow: 20px 30px 0px rgba(0, 0, 0, 0.4);
        }

        @@keyframes shadow {
            from

        {
            box-shadow: 0px 0px 0px rgb(55, 104, 91);
        }

        to {
            box-shadow: 0px 0px 15px rgb(55, 104, 91);
        }

        }

        @@media (max-width : 570px) {
            .backbtn

        {
            height: 15vmin;
            width: 15vmin;
            background-color: rgb(198, 254, 230);
            animation: shadow;
            animation-duration: 1s;
            animation-timing-function: linear;
            animation-iteration-count: infinite;
            font-size: 1rem;
        }

        .content {
            width: 100%;
        }

        .row {
            margin-top: 2rem;
            padding: 10px;
        }

        }
    </style>
</head>
<body>
    <div class="container">
        <div class="loader loader-vis"></div>
        <div class="row d-flex py-sm-3 justify-content-center flex-wrap align-items-center">
            <div class="col-sm-10 bg-white main py-4 d-flex justify-content-center m-5  rounded-5 overflow-hidden p-2 pt-0">
                <div class="btn" style="position: absolute; margin-top: 8vmin; margin-right: 55vmin;">
                    <a class="btn backbtn rounded-circle d-flex justify-content-center align-items-center fw-bold" asp-action="index">Back</a>
                </div>
                <div class="content pt-3 mt-0">
                    <img class="w-75 mx-5 " src="~/webImages/login-image.jpg" alt="">

                    <form method="post" asp-action="checkLogin" style="display: flex;justify-content: center;flex-wrap: wrap;width: 100%;">
                        <label for="username" class="fw-bold my-2 fs-3">Username</label>
                        <input type="text" name="username" placeholder="Username" class="form-control bg-secondary-subtle border-0 p-1 px-2 fs-3 fw-bold">
                        <label for="password" class="fw-bold my-2 fs-3">Password</label>
                        <input type="password" id="pass" name="password" placeholder="Password" class="form-control bg-secondary-subtle border-0 p-1 px-2 fs-3  fw-bold">
                        <div class="w-100 mt-2 d-flex align-items-center gap-2 align-content-center fs-6 showpass mx-3">
                            <input type="checkbox" class="text-start" onclick="myFunction()">Show Password

                        </div>
                        <!-- <p class="w-100 fs-6 fw-bold text-end"><a href="./foget-admin-password.html" class="text-decoration-none text-secondary" >Forgot password?</a></p> -->

                        <button class="btn btn-success rounded-pill px-sm-5 fs-3 w-75 fw-bold mt-0">Login</button>
                        <br />
                        @TempData["loginerror"]
                    </form>

                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>

    <script>
                function myFunction() {
          var x = document.getElementById("pass");
          if (x.type === "password") {
            x.type = "text";
          } else {
            x.type = "password";
          }
        }
    </script>

    <script src="./script.js">


    </script>
</body>
</html>